<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/notif_reaction_pick_title"
        android:textColor="#1E1E2F"
        android:textSize="16sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/reaction_emoji_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/react_emoji_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/notif_emoji_touch_bg"
                android:gravity="center"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="👍"
                android:textSize="26sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/react_emoji_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/notif_emoji_touch_bg"
                android:gravity="center"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="❤️"
                android:textSize="26sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/react_emoji_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/notif_emoji_touch_bg"
                android:gravity="center"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="😂"
                android:textSize="26sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/react_emoji_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/notif_emoji_touch_bg"
                android:gravity="center"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="😮"
                android:textSize="26sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/react_emoji_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/notif_emoji_touch_bg"
                android:gravity="center"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="😢"
                android:textSize="26sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/react_emoji_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/notif_emoji_touch_bg"
                android:gravity="center"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="🙏"
                android:textSize="26sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
