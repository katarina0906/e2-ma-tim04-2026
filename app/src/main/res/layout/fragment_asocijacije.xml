<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingBottom="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                        android:id="@+id/asoRoundText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Runda 1 / 2"
                        android:textColor="#1E1E2F"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/asoTurnText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Na potezu: Igrač 1"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/asoTimerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#EFEAF8"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:text="⏱ 2:00"
                    android:textColor="#6F4BB2"
                    android:textStyle="bold" />
            </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/asoScoreP1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#EFEAF8"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Igrač 1: 0"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/asoScoreP2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="#F5F5F5"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Igrač 2: 0"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/asoRoundPointsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Ova runda - Igrač 1: 0  Igrač 2: 0"
                    android:textColor="#777777"
                    android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/asoPhaseHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="Otvori jedno skriveno polje."
            android:textColor="#6F4BB2"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/aso_pass_strip_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp">

                <Button
                    android:id="@+id/asoPassGuessButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@drawable/aso_ic_arrow_forward"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:text="@string/aso_pass_next_turn"
                    android:textAllCaps="false"
                    android:textColor="#6F4BB2"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/aso_column_panel_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_col_letter_circle"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/aso_b00"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b01"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b02"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b03"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/aso_title0"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/aso_title_field_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:padding="6dp"
                        android:text="•••••"
                        android:textColor="#4A148C"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/aso_column_panel_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_col_letter_circle"
                        android:gravity="center"
                        android:text="B"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/aso_b10"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b11"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b12"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b13"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/aso_title1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/aso_title_field_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:padding="6dp"
                        android:text="•••••"
                        android:textColor="#4A148C"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/asoFinalCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#4A148C"
                app:cardCornerRadius="16dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:letterSpacing="0.08"
                        android:text="KONAČNO REŠENJE"
                        android:textColor="#FFD54F"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/asoFinalTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/aso_final_field_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:minHeight="56dp"
                        android:padding="12dp"
                        android:text="• • • • • • •"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/aso_column_panel_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_col_letter_circle"
                        android:gravity="center"
                        android:text="C"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/aso_b20"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b21"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b22"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b23"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/aso_title2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/aso_title_field_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:padding="6dp"
                        android:text="•••••"
                        android:textColor="#4A148C"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/aso_column_panel_bg"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_col_letter_circle"
                        android:gravity="center"
                        android:text="D"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/aso_b30"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b31"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b32"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/aso_b33"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/aso_cell_panel"
                        android:minHeight="40dp"
                        android:text="?"
                        android:textAllCaps="false"
                        android:textColor="#1E1E2F"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/aso_title3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/aso_title_field_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:padding="6dp"
                        android:text="•••••"
                        android:textColor="#4A148C"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/asoResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text=""
            android:textColor="#4A3F5C"
            android:textSize="14sp" />

        <Button
            android:id="@+id/asoNextRoundButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Naredna runda"
            android:textAllCaps="false"
            android:visibility="gone" />

        <Button
            android:id="@+id/asoNewGameButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Nova igra (od početka)"
            android:textAllCaps="false"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
