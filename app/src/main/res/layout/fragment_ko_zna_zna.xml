<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:orientation="vertical"
    android:padding="14dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/questionCounterText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pitanje 1 / 5"
                        android:textColor="#1E1E2F"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Oba igraca odgovaraju"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/timerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#EFEAF8"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:text="⏱ 5s"
                    android:textColor="#6F4BB2"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/kzzAvatar0"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/player_avatar_background"
                    android:clipToOutline="true"
                    android:contentDescription="Profilna slika prvog igraca"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/kzzScore0"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#EFEAF8"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Igrač 1: 0"
                    android:textColor="#1E1E2F"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/kzzAvatar1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/player_avatar_background"
                    android:clipToOutline="true"
                    android:contentDescription="Profilna slika drugog igraca"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/kzzScore1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="#F5F5F5"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Igrač 2: 0"
                    android:textColor="#1E1E2F"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Koji je glavni grad Srbije?"
                android:textColor="#1E1E2F"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Izaberi jedan od ponuđenih odgovora."
                android:textColor="#777777"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/answerA"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginBottom="10dp"
        android:text="Beograd"
        android:textAllCaps="false"
        android:textSize="16sp" />

    <Button
        android:id="@+id/answerB"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginBottom="10dp"
        android:text="Novi Sad"
        android:textAllCaps="false"
        android:textSize="16sp" />

    <Button
        android:id="@+id/answerC"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginBottom="10dp"
        android:text="Niš"
        android:textAllCaps="false"
        android:textSize="16sp" />

    <Button
        android:id="@+id/answerD"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Kragujevac"
        android:textAllCaps="false"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/resultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text=""
        android:textColor="#6F4BB2"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
