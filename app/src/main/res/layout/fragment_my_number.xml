<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/myNumberScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Runda 1 / 2"
                            android:textColor="#1E1E2F"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/myNumberStatusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Prvo zaustavi trazeni broj, zatim zaustavi ponudjene brojeve."
                            android:textColor="#666666"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/myNumberTimerValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#EFEAF8"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:text="60s"
                        android:textColor="#6F4BB2"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#EFEAF8"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Igrač 1: 0"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="#F5F5F5"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Igrač 2: 0"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/myNumberResultBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/myNumberResultTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tacan rezultat"
                        android:textColor="#1E1E2F"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/myNumberResultMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Izraz je pogodio trazeni broj i osvojeno je 10 bodova."
                        android:textColor="#4D4D4D"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/targetCountdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Automatski ce se prikazati za 5s"
                    android:textColor="#6C6780"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trazeni broj"
                    android:textColor="#1E1E2F"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/targetValue"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="12dp"
                    android:background="#FFF5D6"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#A86400"
                    android:textSize="38sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stopTargetButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stop broj"
                        android:textAllCaps="false"
                        app:backgroundTint="#6F4BB2"
                        app:cornerRadius="18dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/numbersCountdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Automatski ce se otvoriti za 5s"
                    android:textColor="#6C6780"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ponudjeni brojevi"
                    android:textColor="#1E1E2F"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:columnCount="3"
                    android:rowCount="2">

                    <TextView
                        android:id="@+id/number1"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="#F6F2FF"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#1E1E2F"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/number2"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="#F6F2FF"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#1E1E2F"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/number3"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="#F6F2FF"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#1E1E2F"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/number4"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="#F6F2FF"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#1E1E2F"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/number5"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="#FDF4E7"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#A86400"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/number6"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="#EDF8F1"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="#217A4A"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </GridLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/stopNumbersButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:enabled="false"
                    android:text="Stop brojevi"
                    android:textAllCaps="false"
                    app:backgroundTint="#6F4BB2"
                    app:cornerRadius="18dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Brojeve mozes zaustaviti klikom na dugme ili protresanjem telefona."
                    android:textColor="#6C6780"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Izraz"
                    android:textColor="#1E1E2F"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Dostupni operandi: ( ) + - * /"
                    android:textColor="#6C6780"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Unesi izraz"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/expressionInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:focusable="false"
                        android:inputType="text"
                        android:text="" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openParenthesisButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="("
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/closeParenthesisButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:text=")"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/plusButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:text="+"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/minusButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:text="-"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/multiplyButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="*"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/divideButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:text="/"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/backspaceButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:text="Obrisi"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clearExpressionButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:text="Reset"
                        android:textAllCaps="false"
                        android:textColor="#6F4BB2"
                        app:strokeColor="#6F4BB2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/checkExpressionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:enabled="false"
                    android:text="Proveri rezultat"
                    android:textAllCaps="false"
                    app:backgroundTint="#6F4BB2"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rezultat runde"
                    android:textColor="#1E1E2F"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:background="#F6F2FF"
                        android:gravity="center"
                        android:text="Rezultat"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resultValue"
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="#FFF5D6"
                        android:gravity="center"
                        android:text="-"
                        android:textColor="#A86400"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/scoreValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 bodova"
                    android:textColor="#217A4A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
