<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/target_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#1E1E2F"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="Čet" />

                <TextView
                    android:id="@+id/target_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#6C6780"
                    android:textSize="14sp"
                    tools:text="Regionalni razgovori" />

                <TextView
                    android:id="@+id/target_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="#EFEAF8"
                    android:padding="14dp"
                    android:textColor="#1E1E2F"
                    android:textSize="15sp"
                    tools:text="Ovde se otvara sadržaj vezan za notifikaciju." />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
