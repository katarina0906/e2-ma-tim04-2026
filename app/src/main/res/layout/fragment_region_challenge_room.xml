<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/regionChallengeRoomTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#1E1E2F"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/regionChallengeRoomMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#5F5A73"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/regionChallengeRoomParticipants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#1E1E2F"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/regionChallengeRoomScoreInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="#6B52AE"
                    android:hint="Ukupni poeni"
                    android:inputType="number"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/regionChallengeRoomPlayButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Udji u partiju"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/regionChallengeRoomStartButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Pokreni izazov"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/regionChallengeRoomFinishButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Zavrsi izazov"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/regionChallengeRoomSubmitButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Pošalji rezultat"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
