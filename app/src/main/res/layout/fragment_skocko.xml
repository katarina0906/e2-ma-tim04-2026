<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:paddingBottom="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/skRoundText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Runda 1 / 2"
                            android:textColor="#1E1E2F"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/skStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Priprema"
                            android:textColor="#666666"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/skTimerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#EFEAF8"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:text="⏱ 0:30"
                        android:textColor="#6F4BB2"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/skScore0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#EFEAF8"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Igrač 1: 0"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/skScore1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="#F5F5F5"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Igrač 2: 0"
                        android:textColor="#1E1E2F"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/sk_hint_feedback"
            android:textColor="#666666"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/skHistoryBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.cardview.widget.CardView
            android:id="@+id/skStealCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFF8E1"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sk_steal_title"
                    android:textColor="#E65100"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/sk_steal_hint"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sk_palette_label"
            android:textColor="#1E1E2F"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/skPal0"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/skocko_slot_bg"
                    android:contentDescription="@string/sk_sym_skocko"
                    android:gravity="center"
                    android:text="☺"
                    android:textColor="#7E57C2"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/skPal1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/skocko_slot_bg"
                    android:contentDescription="@string/sk_sym_kvadrat"
                    android:gravity="center"
                    android:text="■"
                    android:textColor="#7E57C2"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/skPal2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/skocko_slot_bg"
                    android:contentDescription="@string/sk_sym_krug"
                    android:gravity="center"
                    android:text="●"
                    android:textColor="#7E57C2"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/skPal3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/skocko_slot_bg"
                    android:contentDescription="@string/sk_sym_herc"
                    android:gravity="center"
                    android:text="♥"
                    android:textColor="#7E57C2"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/skPal4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/skocko_slot_bg"
                    android:contentDescription="@string/sk_sym_trougao"
                    android:gravity="center"
                    android:text="▲"
                    android:textColor="#7E57C2"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/skPal5"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/skocko_slot_bg"
                    android:contentDescription="@string/sk_sym_zvezda"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#7E57C2"
                    android:textSize="28sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/sk_draft_label"
            android:textColor="#1E1E2F"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/skDraft0"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/skocko_slot_bg"
                android:contentDescription="@string/sk_draft_slot"
                android:gravity="center"
                android:textColor="#7E57C2"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/skDraft1"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/skocko_slot_bg"
                android:contentDescription="@string/sk_draft_slot"
                android:gravity="center"
                android:textColor="#7E57C2"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/skDraft2"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/skocko_slot_bg"
                android:contentDescription="@string/sk_draft_slot"
                android:gravity="center"
                android:textColor="#7E57C2"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/skDraft3"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/skocko_slot_bg"
                android:contentDescription="@string/sk_draft_slot"
                android:gravity="center"
                android:textColor="#7E57C2"
                android:textSize="26sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/skClearButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/sk_clear"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/skSubmitButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sk_submit"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/skResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="#6F4BB2"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/skNextRoundButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sk_next_round"
            android:textAllCaps="false"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
