<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/waitingRoomTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Čekaonica"
            android:textColor="#1E1E2F"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/waitingRoomStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Povezivanje sa sobom..."
            android:textColor="#666666"
            android:textSize="15sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/waitingRoomCodeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Test soba"
                    android:textColor="#6F4BB2"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/waitingRoomPlayer1Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="#EFEAF8"
                    android:padding="12dp"
                    android:text="Igrac 1: ceka se"
                    android:textColor="#1E1E2F"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/waitingRoomPlayer2Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:text="Igrac 2: ceka se"
                    android:textColor="#1E1E2F"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/waitingRoomConfirmButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Potvrdi spremnost"
            android:textAllCaps="false"
            app:backgroundTint="#6F4BB2"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/waitingRoomResetButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Resetuj test sobu"
            android:textAllCaps="false"
            android:textColor="#6F4BB2"
            app:cornerRadius="18dp"
            app:strokeColor="#6F4BB2" />
    </LinearLayout>
</ScrollView>
