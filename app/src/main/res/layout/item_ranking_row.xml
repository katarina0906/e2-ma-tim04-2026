<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <TextView
        android:id="@+id/ranking_row_rank"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:textColor="#6F4BB2"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/ranking_row_league"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="#EFEAF8"
        android:gravity="center"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/ranking_row_username"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#1E1E2F"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/ranking_row_stars"
        android:layout_width="132dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="#C49000"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
