<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/regionChallengeItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1E1E2F"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/regionChallengeItemMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#5F5A73"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/regionChallengeItemStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#6B52AE"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/regionChallengeItemParticipants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#1E1E2F"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/regionChallengeScoreInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#6B52AE"
            android:hint="Ukupni poeni"
            android:inputType="number"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/regionChallengeJoinButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Prihvati izazov"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/regionChallengeEnterButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Udji u izazov"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/regionChallengeStartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Pokreni izazov"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/regionChallengeSubmitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Pošalji rezultat"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
