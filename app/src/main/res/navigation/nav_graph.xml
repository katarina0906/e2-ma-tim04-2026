<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.slagalicatim04.fragments.LoginFragment"
        android:label="Prijava"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_resetPasswordFragment"
            app:destination="@id/resetPasswordFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.slagalicatim04.fragments.RegisterFragment"
        android:label="Registracija"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_emailVerificationFragment"
            app:destination="@id/emailVerificationFragment" />
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/emailVerificationFragment"
        android:name="com.example.slagalicatim04.fragments.EmailVerificationFragment"
        android:label="Potvrda mejla"
        tools:layout="@layout/fragment_email_verification">
        <action
            android:id="@+id/action_emailVerificationFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.example.slagalicatim04.fragments.ResetPasswordFragment"
        android:label="Reset lozinke"
        tools:layout="@layout/fragment_reset_password">
        <action
            android:id="@+id/action_resetPasswordFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.slagalicatim04.fragments.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.slagalicatim04.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profileFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.example.slagalicatim04.fragments.NotificationsFragment"
        android:label="@string/notifications_title"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/notificationTargetFragment"
        android:name="com.example.slagalicatim04.fragments.NotificationTargetFragment"
        android:label="@string/notification_target_title"
        tools:layout="@layout/fragment_notification_target" />

    <fragment
        android:id="@+id/gamesFragment"
        android:name="com.example.slagalicatim04.fragments.GamesFragment"
        android:label="Games"
        tools:layout="@layout/fragment_games" />

    <fragment
        android:id="@+id/koZnaZnaFragment"
        android:name="com.example.slagalicatim04.fragments.KoZnaZnaFragment"
        android:label="Ko zna zna"
        tools:layout="@layout/fragment_ko_zna_zna" />

    <fragment
        android:id="@+id/spojniceFragment"
        android:name="com.example.slagalicatim04.fragments.SpojniceFragment"
        android:label="Spojnice"
        tools:layout="@layout/fragment_spojnice" />

    <fragment
        android:id="@+id/asocijacijeFragment"
        android:name="com.example.slagalicatim04.fragments.AsocijacijeFragment"
        android:label="Asocijacije"
        tools:layout="@layout/fragment_asocijacije" />

    <fragment
        android:id="@+id/skockoFragment"
        android:name="com.example.slagalicatim04.fragments.SkockoFragment"
        android:label="Skočko"
        tools:layout="@layout/fragment_skocko" />

    <fragment
        android:id="@+id/stepByStepFragment"
        android:name="com.example.slagalicatim04.fragments.StepByStepFragment"
        android:label="Korak po korak"
        tools:layout="@layout/fragment_step_by_step" />

    <fragment
        android:id="@+id/myNumberFragment"
        android:name="com.example.slagalicatim04.fragments.MyNumberFragment"
        android:label="Moj broj"
        tools:layout="@layout/fragment_my_number" />

</navigation>
